{
  "name": "p-select",
  "version": "0.1.3",
  "description": "A select web component built with Lit",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepublishOnly": "npm run build",
    "prepare": "husky",
    "coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "web-component",
    "lit",
    "select"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "author": "",
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.22.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.3",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.27.0",
    "vite": "^6.2.2",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "lit": "^3.3.2"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
